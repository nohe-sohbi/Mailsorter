# MongoDB Configuration
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password

# Backend Configuration
BACKEND_PORT=8080

# Encryption key for storing sensitive data (REQUIRED, min 32 characters)
# Used to encrypt Gmail API credentials stored in the database.
# The server REFUSES to start with this placeholder or the built-in default —
# generate a real one, e.g.:  openssl rand -base64 32
ENCRYPTION_KEY=change-this-to-a-secure-random-string-32chars

# Gmail API Configuration (Optional - can be configured via UI instead)
# Get these from Google Cloud Console: https://console.cloud.google.com/
# If not set here, you'll be prompted to enter them in the Setup page
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URL=http://localhost:3000/auth/callback

# Mistral AI Configuration
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-2411
# Extra retry attempts on transient AI failures (429/5xx/network), after the
# first try. Backoff is exponential with jitter and honors Retry-After. Default 2.
MISTRAL_MAX_RETRIES=2

# Stripe Billing (Optional - Pro = unlimited analyses)
# Leave STRIPE_SECRET_KEY empty to keep the Pro CTA on the waitlist flow.
# Get keys at https://dashboard.stripe.com/apikeys, create a recurring Price,
# and add a webhook endpoint -> {backend}/api/billing/webhook (signing secret below).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# Base URL of the frontend, used for Checkout success/cancel redirects.
APP_BASE_URL=http://localhost:3000

# Observability
# Reported by GET /health and GET /metrics so you can tell which build is live
# (e.g. a git short SHA injected at deploy time). Defaults to "dev".
BUILD_VERSION=dev

# Daily email digest
# Default hour of day (UTC, 0-23) at which the daily recap is sent to users who
# opted in (each user can override it in Réglages). Default 7.
DIGEST_HOUR_UTC=7

# CORS allow-list (comma-separated origins allowed to call the API).
# Leave empty to use the built-in defaults (localhost dev + mailsorter.sohbi.dev).
# Set this when deploying on another domain — no rebuild required.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://example.com
ALLOWED_ORIGINS=

# Frontend Configuration
# Absolute URL of the API, baked into the static build at image build time.
# Leave this UNSET (commented) so both flows work out of the box:
#   - Docker / Dokploy build  -> defaults to "/" (same-origin via the nginx
#     proxy, location /api -> backend:8080; no CORS, no host-specific build)
#   - local `npm start` / dev-start.sh -> api.js falls back to localhost:8080
# Uncomment and set a full URL only if the API lives on a different origin.
#REACT_APP_API_URL=/
